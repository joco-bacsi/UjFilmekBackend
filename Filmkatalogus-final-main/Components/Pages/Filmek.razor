        public static int TimeToNumber(TimeOnly ido) => (ido.Hour * 60) + ido.Minute;
        public static string TimeToString(TimeOnly ido) => ido.ToString("HH:mm");
    }*/

    private FilmekDetails[]? filmek;
    private MufajokDetails[]? mufajok;

    protected override async Task OnInitializedAsync()
    {
        filmek = await Client.GetFilmekAsync();
        mufajok = await MufajClient.GetMufajokAsync();
    }

    private static string FilmUrl(int id) => $"/editfilm/{id}";
    private static string StabUrl(int id) => $"/stab/{id}";

    private async Task GetDeleteModalId(FilmekDetails film)
    {
        await Client.DeleteFilmAsync(film!.Id);
        filmek = await Client.GetFilmekAsync();
    }
}