@page "/Filmek"
@inject FilmekClient Client
@inject MufajClient MufajClient

@attribute [StreamRendering]

@rendermode InteractiveServer
@inject NavigationManager nav
<PageTitle>FilmKatalógus</PageTitle>
<style>
    body{
    background-image: url(chaplin.jpg);
    background-size: auto;
    background-position: center;
    background-repeat: no-repeat;
    .table {
    background-color: rgba(0, 0, 0, 0.3);
    color: rgb(0, 0, 0);
    border: 2px solid #fff;
    border-collapse: collapse;
}

/* fejléc */
.table thead th {
    background-color: rgba(0, 0, 0, 0.7);
    color: rgb(255, 255, 255);
    border: 2px solid white;
    padding: 10px;
}

/* sorok */
.table tbody td {
    background-color: rgba(0, 0, 0, 0.4);
    color: rgb(0, 0, 0);
    border: 2px solid white;
    padding: 10px;
}

/* hover effekt (nagyon dob rajta) */
.table tbody tr:hover {
    background-color: rgba(255, 255, 255, 0.1);
}

/* opcionális: zebra */
.table tbody tr:nth-child(even) td {
    background-color: rgba(255, 255, 255, 0.05);
}
</style>
<div class="mt-2">
        <button class="btn btn-primary" @onclick='() => nav.NavigateTo("/editfilm")'>Új Film hozzáadása</button>
</div>

@if(filmek is null || mufajok is null)
{
    <p><em>Betöltés...</em></p>
}
else
{
    <table class="table table-striped table-bordered table-hover mt-3">
        <thead class="table-dark">
            <th>Id</th>
            <th>Cim</th>    
            <th>Műfaj</th>
            <th>Hossz</th>
            <th>Nyelv</th>
            <th>Megjelenési Dátum</th>
            <th>ImDb Értékelés</th>
            <th>Saját Értékelés</th>
            <th></th>
        </thead>
        <tbody>
            @foreach (var (film, index) in filmek.Select((FilmekDetails f, int i) => (f, i)))
            {
                <tr>
                    <td>@(index+1)</td>                    
                    <td>@film.Cim</td> 
                    <td>@foreach (var m in mufajok)
                        {
                            if (m.Id == film.MufajId)
                            {
                                @m.Name
                            }
                        }
                    
                        </td>             
                    <td>@film.Hossz<p> perc</p></td>
                    <td>@film.Nyelv</td>
                    <td>@film.MegjelenesiDatum.ToString()</td>
                    <td>@film.ImDbErtekeles</td>
                    <td>@film.SajatErtekeles</td>
                    <td>
                        <div class="d-flex">
                            <a class="btn btn-primary me-2" role="button" href="@FilmUrl(film.Id)">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-primary me-2" role="button" href="@StabUrl(film.Id)">
                                <i class="bi bi-search"></i>
                            </a>
                            <button class="btn btn-danger" 
                                    @onclick="@(() => GetDeleteModalId(film))">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                        <DeleteFilm Film="@film" />
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

